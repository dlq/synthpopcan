{
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "reportMissingModuleSource": "none",
  "extraPaths": ["src"],
  "exclude": [
    "tests",
    "scripts",
    "docs",
    "**/.venv",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "node_modules",
    "dist"
  ]
}
